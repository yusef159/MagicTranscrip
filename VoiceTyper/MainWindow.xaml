<Window x:Class="VoiceTyper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceTyper Settings"
        Height="760"
        Width="1120"
        MinHeight="700"
        MinWidth="980"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource VTWindowBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="VoiceTyper"
                           Style="{StaticResource VTTitleTextStyle}"/>
                <TextBlock Text="Modern settings workspace"
                           Style="{StaticResource VTSecondaryTextStyle}"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,2,0">
                <TextBlock Text="Dark mode"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <ToggleButton x:Name="ThemeToggle"
                              Width="54"
                              Height="30"
                              Style="{StaticResource VTThemeToggleStyle}"
                              Checked="ThemeToggle_Checked"
                              Unchecked="ThemeToggle_Checked"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource VTPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource VTSidebarBackgroundBrush}"
                        CornerRadius="12"
                        Padding="12">
                    <StackPanel>
                        <ListBox x:Name="NavSections"
                                 Style="{StaticResource VTSidebarListStyle}"
                                 SelectionChanged="NavSections_SelectionChanged">
                            <ListBoxItem Content="General" Tag="General" IsSelected="True"/>
                            <ListBoxItem Content="Custom Commands" Tag="Custom"/>
                            <ListBoxItem Content="Usage" Tag="Usage"/>
                            <ListBoxItem Content="Future Tab (placeholder)" Tag="Future"/>
                        </ListBox>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="0,0,6,0">
                        <Border x:Name="GeneralSectionPanel"
                                Visibility="Visible"
                                Style="{StaticResource VTCardStyle}">
                            <StackPanel>
                                <TextBlock Text="General"
                                           Style="{StaticResource VTSectionTitleTextStyle}"/>
                                <TextBlock Text="Hotkeys, recording target, and behavior."
                                           Style="{StaticResource VTSecondaryTextStyle}"
                                           Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Transcript hotkey" Margin="0,0,0,6"/>
                                        <TextBox x:Name="TranscriptHotkeyBox"
                                                 IsReadOnly="True"
                                                 FontFamily="Consolas"
                                                 PreviewKeyDown="TranscriptHotkeyBox_PreviewKeyDown"
                                                 GotFocus="TranscriptHotkeyBox_GotFocus"
                                                 LostFocus="TranscriptHotkeyBox_LostFocus"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Professional hotkey" Margin="0,0,0,6"/>
                                        <TextBox x:Name="ProfessionalHotkeyBox"
                                                 IsReadOnly="True"
                                                 FontFamily="Consolas"
                                                 PreviewKeyDown="ProfessionalHotkeyBox_PreviewKeyDown"
                                                 GotFocus="ProfessionalHotkeyBox_GotFocus"
                                                 LostFocus="ProfessionalHotkeyBox_LostFocus"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Microphone" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="MicrophoneCombo"
                                              Padding="12,10"
                                              MinHeight="46"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ToggleButton x:Name="AutoPasteCheck"
                                                  Width="54"
                                                  Height="30"
                                                  Margin="0,0,10,0"
                                                  Style="{StaticResource VTThemeToggleStyle}"/>
                                    <TextBlock Text="Auto-paste into active window"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="CustomCommandsPanel"
                                Visibility="Collapsed"
                                Style="{StaticResource VTCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Custom Commands"
                                               Style="{StaticResource VTSectionTitleTextStyle}"/>
                                    <Button Content="+ Add custom hotkey"
                                            Width="170"
                                            Click="AddCustomHotkey_Click"
                                            DockPanel.Dock="Right"/>
                                </DockPanel>
                                <TextBlock Text="Create hotkeys with custom instructions."
                                           Style="{StaticResource VTSecondaryTextStyle}"
                                           Margin="0,0,0,14"/>

                                <Border Style="{StaticResource VTInnerPanelStyle}">
                                    <ScrollViewer Height="430"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="CustomHotkeysItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource VTInnerCardStyle}">
                                                        <StackPanel>
                                                            <DockPanel Margin="0,0,0,6">
                                                                <CheckBox Content="Enabled"
                                                                          IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                                          VerticalAlignment="Center"/>
                                                                <Button Content="Remove"
                                                                        Click="RemoveCustomHotkey_Click"
                                                                        DockPanel.Dock="Right"
                                                                        Width="80"/>
                                                            </DockPanel>
                                                            <TextBlock Text="Name" Margin="0,0,0,6"/>
                                                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <TextBlock Text="Hotkey" Margin="0,10,0,6"/>
                                                            <TextBox IsReadOnly="True"
                                                                     FontFamily="Consolas"
                                                                     PreviewKeyDown="CustomHotkeyBox_PreviewKeyDown"
                                                                     GotFocus="CustomHotkeyBox_GotFocus"
                                                                     LostFocus="CustomHotkeyBox_LostFocus"
                                                                     Loaded="CustomHotkeyBox_Loaded"/>
                                                            <TextBlock Text="Instructions" Margin="0,10,0,6"/>
                                                            <TextBox Text="{Binding Instruction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     MinHeight="64"
                                                                     TextWrapping="Wrap"
                                                                     AcceptsReturn="True"
                                                                     VerticalScrollBarVisibility="Auto"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border x:Name="UsagePanel"
                                Visibility="Collapsed"
                                Style="{StaticResource VTCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Word Usage"
                                           Style="{StaticResource VTSectionTitleTextStyle}"/>
                                <TextBlock Text="Recent dictation output stats."
                                           Style="{StaticResource VTSecondaryTextStyle}"
                                           Margin="0,0,0,14"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Style="{StaticResource VTStatCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Today" Style="{StaticResource VTSecondaryTextStyle}"/>
                                            <TextBlock x:Name="TodayWordsText" Text="0 words" Style="{StaticResource VTStatValueTextStyle}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" Style="{StaticResource VTStatCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="This month" Style="{StaticResource VTSecondaryTextStyle}"/>
                                            <TextBlock x:Name="MonthWordsText" Text="0 words" Style="{StaticResource VTStatValueTextStyle}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" Style="{StaticResource VTStatCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="This year" Style="{StaticResource VTSecondaryTextStyle}"/>
                                            <TextBlock x:Name="TotalWordsText" Text="0 words" Style="{StaticResource VTStatValueTextStyle}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" Style="{StaticResource VTStatCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Avg / day" Style="{StaticResource VTSecondaryTextStyle}"/>
                                            <TextBlock x:Name="AverageWordsText" Text="0 words" Style="{StaticResource VTStatValueTextStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="FutureSectionPanel"
                                Visibility="Collapsed"
                                Style="{StaticResource VTCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Future Tab"
                                           Style="{StaticResource VTSectionTitleTextStyle}"/>
                                <TextBlock Text="Placeholder panel kept intentionally so adding new tabs later is straightforward."
                                           TextWrapping="Wrap"
                                           Style="{StaticResource VTSecondaryTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Save"
                    Width="90"
                    Height="34"
                    Click="Save_Click"
                    IsDefault="True"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Width="90"
                    Height="34"
                    Click="Cancel_Click"
                    IsCancel="True"
                    Style="{StaticResource VTSecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
