<Window x:Class="VoiceTyper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceTyper Settings"
        Height="400" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,6,0,2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
            VoiceTyper Settings
        </TextBlock>

        <StackPanel Grid.Row="1">
            <Label Content="Hotkey (press to capture)"/>
            <TextBox x:Name="HotkeyBox" IsReadOnly="True"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     GotFocus="HotkeyBox_GotFocus"
                     LostFocus="HotkeyBox_LostFocus"
                     FontFamily="Consolas"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <Label Content="Microphone"/>
            <ComboBox x:Name="MicrophoneCombo"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <Label Content="Language hint (e.g. en, es, fr — leave blank for auto)"/>
            <TextBox x:Name="LanguageBox"/>
        </StackPanel>

        <CheckBox Grid.Row="4" x:Name="CleanupCheck"
                  Content="Enable transcript cleanup (improves punctuation via AI)"/>

        <CheckBox Grid.Row="5" x:Name="AutoPasteCheck"
                  Content="Auto-paste into active window"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="90" Height="32"
                    Click="Save_Click" IsDefault="True" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="90" Height="32"
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
