<Window x:Class="VoiceTyper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceTyper Settings"
        Height="720" Width="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,6,0,2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
            VoiceTyper Settings
        </TextBlock>

        <StackPanel Grid.Row="1">
            <Label Content="Transcript hotkey"/>
            <TextBox x:Name="TranscriptHotkeyBox" IsReadOnly="True"
                     PreviewKeyDown="TranscriptHotkeyBox_PreviewKeyDown"
                     GotFocus="TranscriptHotkeyBox_GotFocus"
                     LostFocus="TranscriptHotkeyBox_LostFocus"
                     FontFamily="Consolas"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <Label Content="Professional hotkey"/>
            <TextBox x:Name="ProfessionalHotkeyBox" IsReadOnly="True"
                     PreviewKeyDown="ProfessionalHotkeyBox_PreviewKeyDown"
                     GotFocus="ProfessionalHotkeyBox_GotFocus"
                     LostFocus="ProfessionalHotkeyBox_LostFocus"
                     FontFamily="Consolas"/>
        </StackPanel>

        <GroupBox Grid.Row="3" Header="Hotkeys">
            <StackPanel Margin="8,6,8,8">
                <Button Content="+ Add custom hotkey"
                        Width="160"
                        Margin="0,0,0,12"
                        Click="AddCustomHotkey_Click"/>
                <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="8">
                    <ScrollViewer Height="180" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CustomHotkeysItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E6E6E6" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,6">
                                                <CheckBox Content="Enabled"
                                                          IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                          VerticalAlignment="Center"/>
                                                <Button Content="Remove"
                                                        Click="RemoveCustomHotkey_Click"
                                                        DockPanel.Dock="Right"
                                                        Width="70"
                                                        Height="24"/>
                                            </DockPanel>
                                            <Label Content="Name"/>
                                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Label Content="Hotkey"/>
                                            <TextBox IsReadOnly="True"
                                                     FontFamily="Consolas"
                                                     PreviewKeyDown="CustomHotkeyBox_PreviewKeyDown"
                                                     GotFocus="CustomHotkeyBox_GotFocus"
                                                     LostFocus="CustomHotkeyBox_LostFocus"
                                                     Loaded="CustomHotkeyBox_Loaded"/>
                                            <Label Content="Instructions"/>
                                            <TextBox Text="{Binding Instruction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     MinHeight="56"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="4">
            <Label Content="Microphone"/>
            <ComboBox x:Name="MicrophoneCombo"/>
        </StackPanel>

        <CheckBox Grid.Row="5" x:Name="AutoPasteCheck"
                  Margin="0,8,0,0"
                  FontSize="13"
                  Content="Auto-paste into active window"/>

        <GroupBox Grid.Row="6" Header="Word usage" Margin="0,16,0,0">
            <Grid Margin="8,6,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                    <TextBlock Text="Today" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TodayWordsText" Text="0 words" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                    <TextBlock Text="This month" FontWeight="SemiBold"/>
                    <TextBlock x:Name="MonthWordsText" Text="0 words" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="This year" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TotalWordsText" Text="0 words" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="Avg / day" FontWeight="SemiBold"/>
                    <TextBlock x:Name="AverageWordsText" Text="0 words" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="90" Height="32"
                    Click="Save_Click" IsDefault="True" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="90" Height="32"
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
